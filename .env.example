# ═══════════════════════════════════════════════════════════════
#  Vorbestellungs-Kasse – Konfiguration
#  Diese Datei als .env kopieren und anpassen: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# --- Veranstaltung ---
VEREINSNAME="ASG Ettlingen"
EVENT_NAME=Fischerfest
EVENT_JAHR=2026

# --- Datenbank ---
DATABASE_URL=sqlite:///./data/vorbestellungs-kasse.db

# --- Drucker (USB-Gerätepfad auf dem Raspberry Pi) ---
PRINTER_DEVICE=/dev/usb/lp0
PRINTER_ENABLED=true

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- UI-Labels (optional – bei Bedarf anpassen) ---
ABHOLZEIT_LABEL=Abholzeit
TOGO_LABEL=To-Go

# --- CSV-Spaltennamen ---
# Standard entspricht dem WooCommerce SQL-Export.
# Nur ändern, wenn ein anderes Shop-System andere Spaltennamen liefert.
CSV_COL_ORDER_ID=order_id
CSV_COL_TOTAL=net_total
CSV_COL_FIRST_NAME=first_name
CSV_COL_LAST_NAME=last_name
CSV_COL_EMAIL=email
CSV_COL_TIMESLOT=abholzeit
CSV_COL_TOGO=togo
CSV_COL_ITEM_PREFIX=item_
CSV_COL_QUANTITY_PREFIX=quantity_
CSV_ITEM_SLOTS=10

# --- Raspberry Pi / Infrastruktur (nur für scripts/prepare.sh) ---
PI_HOSTNAME=kasse
HOTSPOT_SSID=MeinVerein
HOTSPOT_PASSWORD=MeinPasswort2026
