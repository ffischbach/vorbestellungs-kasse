# ═══════════════════════════════════════════════════════════════
#  Vorbestellungs-Kasse – Konfiguration
#  Diese Datei als .env kopieren und anpassen: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# --- Veranstaltung ---
VEREINSNAME="ASG Ettlingen"
EVENT_NAME=Fischerfest
EVENT_JAHR=2026

# --- Datenbank ---
DATABASE_URL=sqlite:///./data/vorbestellungs-kasse.db

# --- Admin-Passwort (für /admin – Benutzername ist immer "admin") ---
ADMIN_PASSWORD=bitte-aendern

# --- Drucker (USB-Gerätepfad auf dem Raspberry Pi) ---
PRINTER_DEVICE=/dev/usb/lp0
PRINTER_ENABLED=true
PRINTER_FONT=a   # "a" = normal, "b" = klein (weniger Papier)

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- UI-Labels (optional – bei Bedarf anpassen) ---
ABHOLZEIT_LABEL=Abholzeit
TOGO_LABEL=To-Go

# --- CSV-Format ---
# "pivoted"    – eine Zeile pro Bestellung, Produkte als Spaltenpaar item_1/quantity_1 … (WooCommerce-Standard)
# "line_items" – eine Zeile pro Artikel, mehrere Zeilen pro Bestellung (Shopify, Pretix, Eventbrite …)
CSV_FORMAT=pivoted

# --- CSV-Spaltennamen (gemeinsam für beide Formate) ---
# Standard entspricht dem WooCommerce SQL-Export.
CSV_COL_ORDER_ID=order_id
CSV_COL_TOTAL=net_total
CSV_COL_FIRST_NAME=first_name
CSV_COL_LAST_NAME=last_name
CSV_COL_EMAIL=email
CSV_COL_TIMESLOT=abholzeit
CSV_COL_TOGO=togo

# Nur für CSV_FORMAT=pivoted (WooCommerce)
CSV_COL_ITEM_PREFIX=item_
CSV_COL_QUANTITY_PREFIX=quantity_
CSV_ITEM_SLOTS=10

# Nur für CSV_FORMAT=line_items (Shopify, Pretix …)
# Standardwerte: CSV_COL_ITEM_NAME=item_name  CSV_COL_ITEM_QUANTITY=quantity
# Wenn gesetzt: Spalte mit dem Stückpreis pro Zeile → Gesamtsumme wird als sum(Preis×Menge) berechnet.
# Leer lassen wenn csv_col_total bereits die vollständige Bestellsumme enthält (WooCommerce-Verhalten).
CSV_COL_LINE_PRICE=

# ---------------------------------------------------------------------------
# Konfiguration für Export aus dem vorbestellungsshop (apps/web/api/export/orders)
# Folgende Werte überschreiben die Defaults oben – einfach auskommentieren:
# ---------------------------------------------------------------------------
# CSV_FORMAT=line_items
# CSV_COL_ORDER_ID=Bestellnummer
# CSV_COL_FIRST_NAME=Name      # Vor- und Nachname in einem Feld → wird automatisch gesplittet
# CSV_COL_LAST_NAME=           # leer lassen – kein separates Feld im Export
# CSV_COL_EMAIL=E-Mail
# CSV_COL_TIMESLOT=Zeitslot
# CSV_COL_ITEM_NAME=Produkt
# CSV_COL_ITEM_QUANTITY=Menge
# CSV_COL_LINE_PRICE=Preis     # Stückpreis im Export → Gesamtsumme wird berechnet

# --- Raspberry Pi / Infrastruktur (nur für scripts/prepare.sh) ---
PI_HOSTNAME=kasse
HOTSPOT_SSID=MeinVerein
HOTSPOT_PASSWORD=MeinPasswort2026
